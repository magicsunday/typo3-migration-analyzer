###########
# General #
###########

# The PHP version to use.
# Supported versions: 8.3, 8.4
PHP_VERSION=8.4

# Docker compose project name.
# This prevents conflicts with other Docker projects by ensuring unique container names.
COMPOSE_PROJECT_NAME=typo3-migration-analyzer

# HTTPS enforcement setting.
# Options:
#   - TRUE: Forces HTTPS by redirecting all HTTP requests to HTTPS
#   - FALSE: Allows both HTTP and HTTPS connections
ENFORCE_HTTPS=TRUE

# The domain name for accessing the application when using a reverse proxy.
# Do not include http:// or https:// prefixes.
# Note: This is only used when the Traefik configuration is enabled.
DEV_DOMAIN=

################
# Docker stack #
################

# Available configuration options:
#
# 1. Direct port access:
#    - Access the application via HTTP_PORT (default: 8080)
#COMPOSE_FILE=compose.yaml:compose.ports.yaml
#
# 2. With Traefik reverse proxy:
#    - Integrates with Traefik for domain-based access
#    - Supports automatic HTTPS
#COMPOSE_FILE=compose.yaml:compose.traefik.yaml
#
# 3. Development with Traefik:
#    - Local file changes are immediately visible without rebuilding
#    - Integrates with Traefik for domain-based access
#COMPOSE_FILE=compose.yaml:compose.development.yaml:compose.traefik.yaml

COMPOSE_FILE=

#############
# HTTP Port #
#############

# Port mapping for direct access (without Traefik).
# Only used when Traefik is not configured.
HTTP_PORT=8080

############
# Symfony  #
############

# Application environment (prod recommended for deployment)
APP_ENV=prod

# Application secret (CHANGE THIS to a unique random string!)
# Generate one with: openssl rand -hex 16
APP_SECRET=

# Default URI for generating absolute URLs
DEFAULT_URI=https://localhost
