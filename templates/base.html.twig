<!DOCTYPE html>
<html lang="de" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}TYPO3 Migration Analyzer{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YcnS/1p8NdOKEh6eFOnEuQuMKi7LR4Ooh1N+" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <div class="d-flex">
        {# Sidebar #}
        <nav id="sidebar" class="sidebar d-flex flex-column flex-shrink-0 p-3 text-bg-dark" style="width: 280px; min-height: 100vh;">
            <a href="{{ path('dashboard') }}" class="d-flex align-items-center mb-3 mb-md-0 me-md-auto text-white text-decoration-none">
                <i class="bi bi-arrow-repeat me-2 fs-4 text-typo3"></i>
                <span class="fs-5 fw-semibold">TYPO3 Migration</span>
            </a>
            <hr>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a href="{{ path('dashboard') }}" class="nav-link text-white {{ app.request.attributes.get('_route') == 'dashboard' ? 'active bg-typo3' : '' }}">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li>
                    <a href="{{ path('deprecation_list') }}" class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'deprecation' ? 'active bg-typo3' : '' }}">
                        <i class="bi bi-exclamation-triangle me-2"></i>Deprecations
                    </a>
                </li>
                <li>
                    <a href="{{ path('matcher_analysis') }}" class="nav-link text-white {{ app.request.attributes.get('_route') starts with 'matcher' ? 'active bg-typo3' : '' }}">
                        <i class="bi bi-search me-2"></i>Matcher-Analyse
                    </a>
                </li>
            </ul>
            <hr>
            <div class="text-muted small">
                <i class="bi bi-tag me-1"></i>TYPO3 12 &rarr; 13
            </div>
        </nav>

        {# Main content #}
        <div class="flex-grow-1">
            {# Top bar #}
            <header class="navbar navbar-expand-lg bg-white border-bottom px-4 py-2">
                <div class="container-fluid">
                    <button class="btn btn-sm btn-outline-secondary d-lg-none me-3" type="button" onclick="document.getElementById('sidebar').classList.toggle('d-none')">
                        <i class="bi bi-list"></i>
                    </button>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0">
                            {% block breadcrumb %}
                                <li class="breadcrumb-item active">Dashboard</li>
                            {% endblock %}
                        </ol>
                    </nav>
                </div>
            </header>

            {# Page content #}
            <main class="p-4">
                {% block body %}{% endblock %}
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
