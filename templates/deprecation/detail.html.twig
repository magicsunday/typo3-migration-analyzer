{% extends 'base.html.twig' %}

{% block title %}{{ doc.type.value }} #{{ doc.issueId }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('dashboard') }}">Dashboard</a></li>
    <li class="breadcrumb-item"><a href="{{ path('deprecation_list') }}">Deprecations</a></li>
    <li class="breadcrumb-item active">#{{ doc.issueId }}</li>
{% endblock %}

{% block body %}
<div class="mb-4">
    <div class="d-flex align-items-center gap-2 mb-2">
        {% if doc.type.value == 'deprecation' %}
            <span class="badge text-bg-warning">Deprecation</span>
        {% elseif doc.type.value == 'breaking' %}
            <span class="badge text-bg-danger">Breaking</span>
        {% else %}
            <span class="badge text-bg-secondary">{{ doc.type.value }}</span>
        {% endif %}
        <span class="badge text-bg-light text-dark border">{{ doc.version }}</span>
        {% if doc.scanStatus.value == 'fully_scanned' %}
            <span class="badge text-bg-success">Fully Scanned</span>
        {% elseif doc.scanStatus.value == 'partially_scanned' %}
            <span class="badge text-bg-warning">Partially Scanned</span>
        {% else %}
            <span class="badge text-bg-danger">Not Scanned</span>
        {% endif %}
        {% if complexity is defined %}
            {% if complexity.score <= 2 %}
                <span class="badge text-bg-success" title="{{ complexity.reason }}">Complexity {{ complexity.score }}/5</span>
            {% elseif complexity.score == 3 %}
                <span class="badge text-bg-warning" title="{{ complexity.reason }}">Complexity {{ complexity.score }}/5</span>
            {% else %}
                <span class="badge text-bg-danger" title="{{ complexity.reason }}">Complexity {{ complexity.score }}/5</span>
            {% endif %}
            {% if complexity.automatable %}
                <span class="badge text-bg-info">Automatable</span>
            {% endif %}
        {% endif %}
    </div>
    <h1 class="h3 mb-1">#{{ doc.issueId }} &mdash; {{ doc.title }}</h1>
    {% if doc.indexTags|length > 0 %}
        <div class="mt-2">
            {% for tag in doc.indexTags %}
                <span class="badge bg-light text-muted border me-1">{{ tag }}</span>
            {% endfor %}
        </div>
    {% endif %}
</div>

{# Content sections #}
<div class="row">
    <div class="col-lg-8">
        {% if doc.description|trim %}
        <div class="rst-section">
            <h6 class="text-uppercase text-muted small fw-bold mb-3">
                <i class="bi bi-card-text me-1"></i>Description
            </h6>
            <pre>{{ doc.description }}</pre>
        </div>
        {% endif %}

        {% if doc.impact|trim %}
        <div class="rst-section">
            <h6 class="text-uppercase text-muted small fw-bold mb-3">
                <i class="bi bi-exclamation-diamond me-1"></i>Impact
            </h6>
            <pre>{{ doc.impact }}</pre>
        </div>
        {% endif %}

        {% if doc.migration|trim %}
        <div class="rst-section">
            <h6 class="text-uppercase text-muted small fw-bold mb-3">
                <i class="bi bi-arrow-right-circle me-1"></i>Migration
            </h6>
            <pre>{{ doc.migration }}</pre>
        </div>
        {% endif %}

        {% if doc.codeBlocks|length > 0 %}
        <div class="rst-section">
            <h6 class="text-uppercase text-muted small fw-bold mb-3">
                <i class="bi bi-code-slash me-1"></i>Code-Vergleich
                <span class="badge rounded-pill text-bg-primary ms-1">{{ doc.codeBlocks|length }}</span>
            </h6>

            {% set before_labels = ['before', 'vorher'] %}
            {% set after_labels = ['after', 'nachher'] %}
            {% set pair_labels = before_labels|merge(after_labels) %}

            {# Check if there are Before/After pairs #}
            {% set has_pairs = false %}
            {% for block in doc.codeBlocks %}
                {% if block.label is not null and block.label|lower in pair_labels %}
                    {% set has_pairs = true %}
                {% endif %}
            {% endfor %}

            {% if has_pairs %}
                {# Side-by-side comparison for Before/After pairs #}
                <div class="code-comparison mb-3">
                    {% for block in doc.codeBlocks %}
                        {% if block.label is not null and block.label|lower in before_labels %}
                            <div class="code-panel">
                                <div class="code-panel-header before">
                                    <i class="bi bi-x-circle me-1"></i>Before (veraltet)
                                </div>
                                <pre><code class="hljs-code language-{{ block.language }}">{{ block.code }}</code></pre>
                            </div>
                        {% elseif block.label is not null and block.label|lower in after_labels %}
                            <div class="code-panel">
                                <div class="code-panel-header after">
                                    <i class="bi bi-check-circle me-1"></i>After (neu)
                                </div>
                                <pre><code class="hljs-code language-{{ block.language }}">{{ block.code }}</code></pre>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>

                {# Show any unlabeled blocks separately #}
                {% for block in doc.codeBlocks %}
                    {% if block.label is null or block.label|lower not in pair_labels %}
                        <div class="code-single mb-3">
                            <div class="code-panel-header neutral">
                                <i class="bi bi-file-code me-1"></i>{{ block.language|upper }}
                                {% if block.label %} — {{ block.label }}{% endif %}
                            </div>
                            <pre><code class="hljs-code language-{{ block.language }}">{{ block.code }}</code></pre>
                        </div>
                    {% endif %}
                {% endfor %}
            {% else %}
                {# Sequential display for non-paired blocks #}
                {% for block in doc.codeBlocks %}
                    <div class="code-single mb-3">
                        <div class="code-panel-header neutral">
                            <i class="bi bi-file-code me-1"></i>{{ block.language|upper }}
                            {% if block.label %} — {{ block.label }}{% endif %}
                        </div>
                        <pre><code class="hljs-code language-{{ block.language }}">{{ block.code }}</code></pre>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
        {% endif %}
    </div>

    <div class="col-lg-4">
        {% if mappings|length > 0 %}
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <h6 class="card-title mb-0">
                    <i class="bi bi-arrow-left-right me-1"></i>Migration-Mappings
                    <span class="badge rounded-pill text-bg-primary ms-1">{{ mappings|length }}</span>
                </h6>
            </div>
            <div class="list-group list-group-flush">
                {% for mapping in mappings %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <span class="badge text-bg-danger">Alt</span>
                        {% if mapping.confidence >= 1.0 %}
                            <span class="badge text-bg-success">{{ mapping.confidence|number_format(1) }}</span>
                        {% elseif mapping.confidence >= 0.9 %}
                            <span class="badge text-bg-warning">{{ mapping.confidence|number_format(1) }}</span>
                        {% else %}
                            <span class="badge text-bg-secondary">{{ mapping.confidence|number_format(1) }}</span>
                        {% endif %}
                    </div>
                    <code class="small text-break">{{ mapping.source.className }}{% if mapping.source.member %}{% if mapping.source.className %}::{% endif %}{{ mapping.source.member }}{% endif %}</code>
                    <div class="text-center my-1">
                        <i class="bi bi-arrow-down text-muted"></i>
                    </div>
                    <div class="d-flex align-items-start">
                        <span class="badge text-bg-success me-1">Neu</span>
                    </div>
                    <code class="small text-break">{{ mapping.target.className }}{% if mapping.target.member %}{% if mapping.target.className %}::{% endif %}{{ mapping.target.member }}{% endif %}</code>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {% if doc.codeReferences|length > 0 %}
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent">
                <h6 class="card-title mb-0">
                    <i class="bi bi-code-slash me-1"></i>Code-Referenzen
                    <span class="badge rounded-pill text-bg-primary ms-1">{{ doc.codeReferences|length }}</span>
                </h6>
            </div>
            <div class="list-group list-group-flush">
                {% for ref in doc.codeReferences %}
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="text-break">
                            <code class="small">{{ ref.className }}</code>
                            {% if ref.member %}
                                <br><span class="text-muted small">::</span><code class="small text-primary">{{ ref.member }}</code>
                            {% endif %}
                        </div>
                        <span class="badge text-bg-secondary ms-2">{{ ref.type.value }}</span>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="card-title mb-0">
                    <i class="bi bi-robot me-1"></i>LLM Analysis
                </h6>
                {% if llmResult is defined and llmResult %}
                    <button class="btn btn-sm btn-outline-primary" id="llm-reanalyze"
                            data-url="{{ path('llm_analyze_single', {filename: doc.filename}) }}">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                {% endif %}
            </div>
            <div class="card-body" id="llm-result">
                {% if llmResult is defined and llmResult %}
                    <div class="d-flex gap-2 mb-2">
                        {% if llmResult.score <= 2 %}
                            <span class="badge text-bg-success">Score {{ llmResult.score }}/5</span>
                        {% elseif llmResult.score == 3 %}
                            <span class="badge text-bg-warning">Score {{ llmResult.score }}/5</span>
                        {% else %}
                            <span class="badge text-bg-danger">Score {{ llmResult.score }}/5</span>
                        {% endif %}
                        {% if llmResult.automationGrade.value == 'full' %}
                            <span class="badge text-bg-success">Full Automation</span>
                        {% elseif llmResult.automationGrade.value == 'partial' %}
                            <span class="badge text-bg-warning">Partial Automation</span>
                        {% else %}
                            <span class="badge text-bg-danger">Manual</span>
                        {% endif %}
                    </div>
                    <p class="small mb-2">{{ llmResult.summary }}</p>
                    {% if llmResult.reasoning %}
                        <p class="small text-muted fst-italic mb-2">{{ llmResult.reasoning }}</p>
                    {% endif %}
                    {% if llmResult.migrationSteps|length > 0 %}
                        <h6 class="small fw-bold text-muted mt-3 mb-1">Migration Steps</h6>
                        <ol class="small mb-2">
                            {% for step in llmResult.migrationSteps %}
                                <li>{{ step }}</li>
                            {% endfor %}
                        </ol>
                    {% endif %}
                    {% if llmResult.affectedAreas|length > 0 %}
                        <div class="mt-2">
                            {% for area in llmResult.affectedAreas %}
                                <span class="badge bg-light text-muted border me-1">{{ area }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if llmResult.affectedComponents|length > 0 %}
                        <div class="mt-2">
                            {% for component in llmResult.affectedComponents %}
                                <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25 me-1">{{ component }}</span>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if llmResult.codeMappings|length > 0 %}
                        <h6 class="small fw-bold text-muted mt-3 mb-1">Code Mappings</h6>
                        <div class="small mb-2">
                            {% for mapping in llmResult.codeMappings %}
                                <div class="d-flex align-items-start gap-2 mb-1">
                                    <code class="text-danger text-break">{{ mapping.old }}</code>
                                    <i class="bi bi-arrow-right text-muted flex-shrink-0"></i>
                                    {% if mapping.new %}
                                        <code class="text-success text-break">{{ mapping.new }}</code>
                                    {% else %}
                                        <span class="text-muted fst-italic">removed</span>
                                    {% endif %}
                                    <span class="badge bg-light text-muted border ms-auto flex-shrink-0">{{ mapping.type }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                    {% if llmResult.rectorAssessment is not null %}
                        <div class="mt-2 small border-top pt-2">
                            <i class="bi bi-gear me-1"></i>
                            <strong>Rector:</strong>
                            {% if llmResult.rectorAssessment.feasible %}
                                <span class="text-success">Automatable</span>
                                {% if llmResult.rectorAssessment.ruleType %}
                                    <span class="text-muted">via {{ llmResult.rectorAssessment.ruleType }}</span>
                                {% endif %}
                            {% else %}
                                <span class="text-danger">Not automatable</span>
                            {% endif %}
                            {% if llmResult.rectorAssessment.notes %}
                                <br><span class="text-muted">{{ llmResult.rectorAssessment.notes }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                    <div class="text-muted small mt-3 border-top pt-2">
                        <i class="bi bi-cpu me-1"></i>{{ llmResult.modelId }}<br>
                        <i class="bi bi-lightning me-1"></i>{{ llmResult.tokensInput + llmResult.tokensOutput }} Tokens, {{ llmResult.durationMs }}ms
                    </div>
                {% else %}
                    <p class="text-muted mb-2">Not yet analyzed.</p>
                    <button class="btn btn-sm btn-typo3" id="llm-analyze-now"
                            data-url="{{ path('llm_analyze_single', {filename: doc.filename}) }}">
                        <i class="bi bi-play me-1"></i>Analyze now
                    </button>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="mt-4">
    <a href="{{ path('deprecation_list') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Zurück zur Liste
    </a>
</div>
{% endblock %}

{% block javascripts %}
    <script src="/js/llm-analysis.js?v=3"></script>
{% endblock %}
