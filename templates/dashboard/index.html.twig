{% extends 'base.html.twig' %}

{% block title %}Dashboard - TYPO3 Migration Analyzer{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Dashboard</li>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">TYPO3 12 &rarr; 13 Migration Coverage</p>
    </div>
</div>

{# Stat cards #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-file-earmark-text"></i>
                </div>
                <div class="stat-value">{{ totalDocuments }}</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">RST-Dokumente</h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Gesamtzahl aller geparseten Deprecation- und Breaking-Change-Dokumente aus dem TYPO3 Changelog.</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div class="stat-value">{{ totalDeprecations }}</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">Deprecations</h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Als veraltet markierte APIs, die in einer zukünftigen Version entfernt werden. Code sollte zeitnah migriert werden.</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-lightning"></i>
                </div>
                <div class="stat-value">{{ totalBreaking }}</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">Breaking Changes</h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Bereits entfernte oder geänderte APIs, die zu Fehlern führen, wenn bestehender Code nicht angepasst wird.</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-puzzle"></i>
                </div>
                <div class="stat-value">{{ totalMatchers }}</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">Matcher-Einträge</h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Konfigurierte Regeln im TYPO3 Extension Scanner, die betroffenen Code in Extensions automatisch erkennen.</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon {{ coverage.coveragePercent >= 80 ? 'bg-success' : (coverage.coveragePercent >= 50 ? 'bg-warning' : 'bg-danger') }} bg-opacity-10 {{ coverage.coveragePercent >= 80 ? 'text-success' : (coverage.coveragePercent >= 50 ? 'text-warning' : 'text-danger') }}">
                    <i class="bi bi-shield-check"></i>
                </div>
                <div class="stat-value">{{ coverage.coveragePercent|number_format(1) }}%</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">
                    <a href="{{ path('coverage_report') }}" class="text-decoration-none text-reset">Matcher-Coverage</a>
                </h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Anteil der RST-Dokumente, für die bereits ein passender Extension-Scanner-Matcher existiert.</small>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card stat-card text-center border-0 shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div class="stat-value">{{ coverage.uncovered|length }}</div>
            </div>
            <div class="card-body">
                <h5 class="card-title">
                    <a href="{{ path('coverage_report') }}" class="text-decoration-none text-reset">Ohne Matcher</a>
                </h5>
            </div>
            <div class="card-footer">
                <small class="text-muted">Dokumente ohne zugehörigen Matcher &mdash; diese Änderungen werden vom Extension Scanner nicht erkannt.</small>
            </div>
        </div>
    </div>
</div>

{# Coverage bar #}
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title mb-0">
                <a href="{{ path('coverage_report') }}" class="text-decoration-none">Matcher-Coverage</a>
            </h6>
            <span class="text-muted small">{{ coverage.covered|length }} / {{ coverage.totalDocuments }} Dokumente abgedeckt</span>
        </div>
        <div class="progress progress-thick">
            <div class="progress-bar {{ coverage.coveragePercent >= 80 ? 'bg-success' : (coverage.coveragePercent >= 50 ? 'bg-warning' : 'bg-danger') }}"
                 role="progressbar"
                 style="width: {{ coverage.coveragePercent }}%"
                 aria-valuenow="{{ coverage.coveragePercent }}"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>
        <small class="text-muted mt-2 d-block">Der Fortschrittsbalken zeigt, wie viele der dokumentierten Änderungen durch bestehende Matcher-Regeln abgedeckt sind. Ziel ist 100% &mdash; jede nicht abgedeckte Änderung kann in Extensions unentdeckt bleiben.</small>
    </div>
</div>

{# Coverage breakdown #}
<div class="row g-3 mt-0">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title mb-3">Coverage nach Version</h6>
                {% for item in coverage.byVersion %}
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>{{ item.label }}</span>
                        <span class="text-muted">{{ item.covered }}/{{ item.total }} ({{ item.percent|number_format(1) }}%)</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar {{ item.percent >= 80 ? 'bg-success' : (item.percent >= 50 ? 'bg-warning' : 'bg-danger') }}"
                             style="width: {{ item.percent }}%"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="card-title mb-3">Coverage nach Typ</h6>
                {% for item in coverage.byType %}
                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>{{ item.label }}</span>
                        <span class="text-muted">{{ item.covered }}/{{ item.total }} ({{ item.percent|number_format(1) }}%)</span>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar {{ item.percent >= 80 ? 'bg-success' : (item.percent >= 50 ? 'bg-warning' : 'bg-danger') }}"
                             style="width: {{ item.percent }}%"></div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
