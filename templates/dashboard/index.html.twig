{% extends 'base.html.twig' %}

{% block title %}Dashboard - TYPO3 Migration Analyzer{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Dashboard</li>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">TYPO3 12 &rarr; 13 Migration Coverage</p>
    </div>
</div>

{# Stat cards #}
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-file-earmark-text fs-3 text-primary"></i>
                <span class="display-6 fw-bold">{{ totalDocuments }}</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">RST-Dokumente</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Gesamtzahl aller geparseten Deprecation- und Breaking-Change-Dokumente aus dem TYPO3 Changelog.
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-exclamation-triangle fs-3 text-warning"></i>
                <span class="display-6 fw-bold">{{ totalDeprecations }}</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">Deprecations</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Als veraltet markierte APIs, die in einer zukünftigen Version entfernt werden. Code sollte zeitnah migriert werden.
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-lightning fs-3 text-danger"></i>
                <span class="display-6 fw-bold">{{ totalBreaking }}</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">Breaking Changes</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Bereits entfernte oder geänderte APIs, die zu Fehlern führen, wenn bestehender Code nicht angepasst wird.
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-puzzle fs-3 text-info"></i>
                <span class="display-6 fw-bold">{{ totalMatchers }}</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">Matcher-Einträge</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Konfigurierte Regeln im TYPO3 Extension Scanner, die betroffenen Code in Extensions automatisch erkennen.
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-shield-check fs-3 {{ coverage.coveragePercent >= 80 ? 'text-success' : (coverage.coveragePercent >= 50 ? 'text-warning' : 'text-danger') }}"></i>
                <span class="display-6 fw-bold">{{ coverage.coveragePercent|number_format(1) }}%</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">Matcher-Coverage</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Anteil der RST-Dokumente, für die bereits ein passender Extension-Scanner-Matcher existiert.
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card text-center shadow-sm h-100">
            <div class="card-header d-flex justify-content-center align-items-center gap-3">
                <i class="bi bi-x-circle fs-3 text-danger"></i>
                <span class="display-6 fw-bold">{{ coverage.uncovered|length }}</span>
            </div>
            <div class="card-body">
                <h5 class="card-title">Ohne Matcher</h5>
            </div>
            <div class="card-footer text-body-secondary">
                Dokumente ohne zugehörigen Matcher &mdash; diese Änderungen werden vom Extension Scanner nicht erkannt.
            </div>
        </div>
    </div>
</div>

{# Coverage bar #}
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="card-title mb-0">Matcher-Coverage</h6>
            <span class="text-muted small">{{ coverage.covered|length }} / {{ coverage.totalDocuments }} Dokumente abgedeckt</span>
        </div>
        <div class="progress progress-thick">
            <div class="progress-bar {{ coverage.coveragePercent >= 80 ? 'bg-success' : (coverage.coveragePercent >= 50 ? 'bg-warning' : 'bg-danger') }}"
                 role="progressbar"
                 style="width: {{ coverage.coveragePercent }}%"
                 aria-valuenow="{{ coverage.coveragePercent }}"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>
        <small class="text-muted mt-2 d-block">Der Fortschrittsbalken zeigt, wie viele der dokumentierten Änderungen durch bestehende Matcher-Regeln abgedeckt sind. Ziel ist 100% &mdash; jede nicht abgedeckte Änderung kann in Extensions unentdeckt bleiben.</small>
    </div>
</div>
{% endblock %}
